.pagination ul li a:hover,
.pagination ul li span.current {
    background: var(--accent-gold-wcag);
    border-color: var(--accent-gold-wcag);
    color: var(--white);
}

.pagination ul li span.dots {
    background: transparent;
    border-color: transparent;
    color: var(--gray-dark);
}

/* =====================================================
   SINGLE POST — BEM components
   Used in: single.php
   ===================================================== */

/* Page header overrides for single */
.single-header {
    padding-bottom: var(--space-xl);
}

.single-header__cat-link {
    text-decoration: none;
    transition: color var(--transition-fast);
}

.single-header__cat-link:hover {
    color: #8B7718;
}

.single-header__title {
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    line-height: 1.25;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
}

.single-header__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    font-size: var(--font-size-sm);
    color: var(--gray-dark);
    margin-bottom: var(--space-sm);
}

.single-header__meta-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
}

.single-header__meta-item i {
    color: var(--accent-gold);
    font-size: 13px;
}

.single-header__meta-item a {
    color: var(--gray-dark);
    text-decoration: none;
    transition: color var(--transition-fast);
}

.single-header__meta-item a:hover {
    color: var(--accent-gold); /* sobre fondo oscuro del page-header → 4.97:1 ✓ */
}

/* Layout: content + sidebar */
.single-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-3xl);
}

@media (min-width: 1024px) {
    .single-layout {
        grid-template-columns: 2fr 1fr;
    }
}

/* Article */
.single-article {
    min-width: 0; /* prevent overflow in grid */
}

/* Featured image */
.single-featured-image {
    margin-bottom: var(--space-xl);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    background: linear-gradient(135deg, #0A1E3C, #1E4A7A);
}

.single-featured-image__img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16 / 9;
    object-fit: cover;
}

.single-featured-image__caption {
    padding: var(--space-sm) var(--space-md);
    font-size: var(--font-size-xs);
    color: var(--gray-dark);
    background: var(--white-soft);
    border-top: 1px solid var(--gray-light);
    font-style: italic;
}

/* Content (prose) */
.single-content {
    font-size: 1rem;
    line-height: 1.85;
    color: #3a3a3a;
    max-width: 720px;
}

.single-content > * + * {
    margin-top: var(--space-md);
}

.single-content h2 {
    font-size: var(--font-size-2xl);
    margin-top: var(--space-2xl);
    padding-bottom: var(--space-xs);
    border-bottom: 2px solid var(--gray-light);
}

.single-content h3 {
    font-size: var(--font-size-xl);
    margin-top: var(--space-xl);
}

.single-content h4 {
    font-size: var(--font-size-lg);
    margin-top: var(--space-lg);
}

.single-content p {
    margin-bottom: var(--space-md);
}

.single-content a {
    color: var(--primary-dark);
    text-decoration: underline;
    text-decoration-color: var(--accent-gold);
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
}

.single-content a:hover {
    color: var(--accent-gold);
}

.single-content img {
    max-width: 100%;
    height: auto;
    border-radius: var(--border-radius-md);
}

.single-content ul,
.single-content ol {
    padding-left: var(--space-xl);
    margin-bottom: var(--space-md);
}

.single-content ul li,
.single-content ol li {
    margin-bottom: var(--space-xs);
}

.single-content blockquote {
    border-left: 4px solid var(--accent-gold);
    padding: var(--space-md) var(--space-xl);
    background: var(--white-soft);
    border-radius: 0 var(--border-radius-sm) var(--border-radius-sm) 0;
    font-style: italic;
    color: var(--gray-dark);
    margin: var(--space-lg) 0;
}

.single-content blockquote p {
    margin-bottom: 0;
}

.single-content pre,
.single-content code {
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.9em;
    background: var(--white-soft);
    border: 1px solid var(--gray-light);
    border-radius: var(--border-radius-sm);
}

.single-content pre {
    padding: var(--space-md);
    overflow-x: auto;
}

.single-content code {
    padding: 2px 6px;
}

.single-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-md);
    font-size: var(--font-size-sm);
}

.single-content th,
.single-content td {
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--gray-light);
    text-align: left;
}

.single-content th {
    background: var(--primary-dark);
    color: var(--white);
    font-weight: 600;
}

.single-content tr:nth-child(even) td {
    background: var(--white-soft);
}

/* Multi-page links */
.single-page-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs);
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--gray-light);
}

.single-page-links__label {
    font-weight: 600;
    font-size: var(--font-size-sm);
    color: var(--primary-dark);
}

.single-page-links__item a,
.single-page-links__item span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 var(--space-sm);
    border: 1px solid var(--gray-light);
    border-radius: var(--border-radius-sm);
    font-size: var(--font-size-sm);
    transition: background var(--transition-fast), border-color var(--transition-fast),
                color var(--transition-fast);
}

.single-page-links__item a:hover,
.single-page-links__item span {
    background: var(--accent-gold-wcag);
    border-color: var(--accent-gold-wcag);
    color: var(--white);
}

/* Tags */
.single-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs);
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--gray-light);
}

.single-tags__icon {
    color: var(--accent-gold);
    font-size: var(--font-size-sm);
}

.single-tag-chip {
    display: inline-block;
    padding: 3px var(--space-sm);
    background: var(--white-soft);
    border: 1px solid var(--gray-light);
    border-radius: var(--border-radius-full);
    font-size: var(--font-size-xs);
    color: var(--primary-dark);
    text-decoration: none;
    transition: background var(--transition-fast), border-color var(--transition-fast),
                color var(--transition-fast);
}

.single-tag-chip:hover {
    background: var(--accent-gold-wcag);
    border-color: var(--accent-gold-wcag);
    color: var(--white);
}

/* Share buttons */
.single-share {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--gray-light);
}

.single-share__label {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--primary-dark);
    display: flex;
    align-items: center;
    gap: 6px;
}

.single-share__label i {
    color: var(--accent-gold);
}

.single-share__buttons {
    display: flex;
    gap: var(--space-xs);
}

.single-share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--border-radius-full);
    color: var(--white);
    text-decoration: none;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
}

.single-share-btn:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    color: var(--white);
}

.single-share-btn--facebook  { background: #1877F2; }
.single-share-btn--twitter   { background: #000000; }
.single-share-btn--whatsapp  { background: #25D366; }
.single-share-btn--email     { background: var(--primary-dark); }

/* Post navigation */
.single-post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--gray-light);
}

@media (max-width: 640px) {
    .single-post-nav {
        grid-template-columns: 1fr;
    }
}

.single-post-nav__item {
    min-width: 0;
}

.single-post-nav__item--next {
    text-align: right;
}

.single-post-nav__link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm);
    border: 1px solid var(--gray-light);
    border-radius: var(--border-radius-md);
    text-decoration: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast),
                background var(--transition-fast);
}

.single-post-nav__link:hover {
    border-color: var(--accent-gold);
    background: rgba(168, 143, 29, 0.04);
    box-shadow: var(--shadow-sm);
}

.single-post-nav__link--next {
    flex-direction: row-reverse;
    text-align: right;
}

.single-post-nav__thumb {
    width: 60px;
    height: 60px;
    border-radius: var(--border-radius-sm);
    overflow: hidden;
    flex-shrink: 0;
}

.single-post-nav__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.single-post-nav__info {
    flex: 1;
    min-width: 0;
}

.single-post-nav__info--right {
    text-align: right;
}

.single-post-nav__direction {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--accent-gold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 3px;
}

.single-post-nav__item--next .single-post-nav__direction {
    justify-content: flex-end;
}

.single-post-nav__post-title {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--primary-dark);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

/* Related posts section */
.related-posts {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--gray-light);
}

.related-posts__header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
}

.related-posts__title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: #0A1E3C;
    white-space: nowrap;
    margin-bottom: 0;
}

/* Sidebar */
.single-sidebar {
    position: sticky;
    top: 110px;
    align-self: start;
}

@media (max-width: 1023px) {
    .single-sidebar {
        position: static;
    }
}

/* Widget: post list (thumbnails) */
.widget-posts-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
}

.widget-post-item {
    display: flex;
    gap: var(--space-sm);
    align-items: flex-start;
    padding-bottom: var(--space-sm);
    border-bottom: 1px dashed var(--gray-light);
}

.widget-post-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
}

.widget-post-thumb {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
    border-radius: var(--border-radius-sm);
    overflow: hidden;
    display: block;
}

.widget-post-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
}

.widget-post-thumb:hover .widget-post-img {
    transform: scale(1.08);
}

.widget-post-info {
    flex: 1;
    min-width: 0;
}

.widget-post-title {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--primary-dark);
    text-decoration: none;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--transition-fast);
}

.widget-post-title:hover {
    color: var(--accent-gold);
}

.widget-post-date {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--gray-dark);
    margin-top: 3px;
}

/* Comments area */
.single-comments {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--gray-light);
}

.single-comments .comments-title,
.single-comments #reply-title {
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-lg);
}

.single-comments .comment-list {
    list-style: none;
}

.single-comments .comment {
    margin-bottom: var(--space-lg);
    padding: var(--space-lg);
    background: var(--white-soft);
    border-radius: var(--border-radius-md);
    border: 1px solid var(--gray-light);
}

.single-comments .comment-author img {
    border-radius: var(--border-radius-full);
}

.single-comments .comment-meta {
    font-size: var(--font-size-xs);
    color: var(--gray-dark);
    margin-bottom: var(--space-sm);
}

.single-comments .reply a {
    font-size: var(--font-size-xs);
    color: var(--accent-gold);
    font-weight: 600;
}

.single-comments .comment-form label {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: 500;
    margin-bottom: 5px;
    color: var(--primary-dark);
}

.single-comments .comment-form input[type="text"],
.single-comments .comment-form input[type="email"],
.single-comments .comment-form input[type="url"],
.single-comments .comment-form textarea {
    width: 100%;
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--gray-light);
    border-radius: var(--border-radius-sm);
    font-family: var(--font-primary);
    font-size: var(--font-size-sm);
    transition: border-color var(--transition-fast);
    margin-bottom: var(--space-md);
}

.single-comments .comment-form input:focus,
.single-comments .comment-form textarea:focus {
    outline: none;
    border-color: var(--accent-gold);
}

.single-comments .comment-form textarea {
    min-height: 140px;
    resize: vertical;
}

.single-comments .form-submit .submit {
    padding: var(--space-sm) var(--space-xl);
    background: var(--accent-gold);
    color: var(--white);
    border: none;
    border-radius: var(--border-radius-sm);
    font-family: var(--font-primary);
    font-size: var(--font-size-sm);
    font-weight: 600;
    cursor: pointer;
    transition: background var(--transition-fast), transform var(--transition-fast);
}

.single-comments .form-submit .submit:hover {
    background: #8B7718;
    transform: translateY(-2px);
}

/* =====================================================
   SEARCH PAGE
   Used in: search.php
   ===================================================== */

/* Search bar section */
.search-bar-section {
    background: var(--white);
    border-bottom: 1px solid var(--gray-light);
    padding: var(--space-lg) 0;
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    box-shadow: var(--shadow-sm);
}

.search-bar-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
}

.search-bar-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
}

.search-bar-icon {
    position: absolute;
    left: var(--space-md);
    color: var(--gray-dark);
    pointer-events: none;
    font-size: var(--font-size-sm);
}

.search-bar-input {
    flex: 1;
    padding: var(--space-md) var(--space-md) var(--space-md) 2.75rem;
    padding-right: 120px;
    border: 2px solid var(--gray-light);
    border-radius: var(--border-radius-md);
    font-family: var(--font-primary);
    font-size: var(--font-size-base);
    background: var(--white-soft);
    transition: border-color var(--transition-fast), background var(--transition-fast);
}

.search-bar-input:focus {
    outline: none;
    border-color: var(--accent-gold);
    background: var(--white);
}

.search-bar-clear {
    position: absolute;
    right: calc(var(--space-xl) + 80px);
    color: var(--gray-dark);
    padding: var(--space-xs);
    text-decoration: none;
    transition: color var(--transition-fast);
}

.search-bar-clear:hover {
    color: var(--primary-dark);
}

.search-bar-submit {
    position: absolute;
    right: var(--space-xs);
    padding: var(--space-sm) var(--space-lg);
    background: var(--accent-gold-wcag);
    color: var(--white);
    border: none;
    border-radius: var(--border-radius-sm);
    font-family: var(--font-primary);
    font-size: var(--font-size-sm);
    font-weight: 600;
    cursor: pointer;
    transition: background var(--transition-fast);
    white-space: nowrap;
}

.search-bar-submit:hover {
    background: #5A4B00;
}

/* Filters row */
.search-bar-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
}

.search-bar-filter-group {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
}

.search-bar-filter-label {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--gray-dark);
    white-space: nowrap;
}

.search-bar-select {
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--gray-light);
    border-radius: var(--border-radius-sm);
    font-family: var(--font-primary);
    font-size: var(--font-size-xs);
    color: var(--primary-dark);
    background: var(--white);
    cursor: pointer;
    transition: border-color var(--transition-fast);
}

.search-bar-select:focus {
    outline: none;
    border-color: var(--accent-gold);
}

/* Search result item (horizontal card) */
.search-results-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
}

.search-result-item {
    display: flex;
    gap: 0;
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-base), border-color var(--transition-base),
                transform var(--transition-base);
}

.search-result-item:hover {
    box-shadow: var(--shadow-lg);
    border-color: rgba(168, 143, 29, 0.3);
    transform: translateY(-2px);
}

.search-result-item__thumb {
    position: relative;
    width: 200px;
    flex-shrink: 0;
    background: linear-gradient(135deg, #0A1E3C, #1E4A7A);
    overflow: hidden;
}

.search-result-item__thumb--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: rgba(255, 255, 255, 0.2);
    min-height: 140px;
}

@media (max-width: 640px) {
    .search-result-item {
        flex-direction: column;
    }

    .search-result-item__thumb {
        width: 100%;
        height: 180px;
    }
}

.search-result-item__thumb a {
    display: block;
    height: 100%;
}

.search-result-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
}

.search-result-item:hover .search-result-item__img {
    transform: scale(1.06);
}

.search-result-item__type-badge {
    position: absolute;
    top: var(--space-sm);
    left: var(--space-sm);
    padding: 3px var(--space-sm);
    background: var(--accent-gold);
    color: var(--white);
    font-size: var(--font-size-xs);
    font-weight: 600;
    border-radius: var(--border-radius-full);
    z-index: 1;
}

.search-result-item__body {
    flex: 1;
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
}

.search-result-item__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    font-size: var(--font-size-xs);
    color: var(--gray-dark);
    margin-bottom: var(--space-sm);
}

.search-result-item__meta span {
    display: inline-flex;
    align-items: center;
    gap: 4px;
}

.search-result-item__meta i {
    color: var(--accent-gold);
}

.search-result-item__cat {
    color: var(--gray-dark);
    text-decoration: none;
}

.search-result-item__cat:hover {
    color: var(--accent-gold-wcag);
}

.search-result-item__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: #0A1E3C;
    margin-bottom: var(--space-sm);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--transition-fast);
    line-height: 1.35;
}

.search-result-item:hover .search-result-item__title {
    color: var(--accent-gold-wcag);
}

.search-result-item__title a {
    color: inherit;
    text-decoration: none;
}

.search-result-item__excerpt {
    font-size: var(--font-size-sm);
    color: var(--gray-dark);
    line-height: 1.65;
    margin-bottom: var(--space-md);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

/* Search highlight <mark> */
.search-highlight {
    background: rgba(122, 102, 0, 0.1);
    color: var(--accent-gold-wcag); /* #7A6600 — WCAG AA sobre fondo claro */
    font-weight: 600;
    padding: 0 3px;
    border-radius: 3px;
}

/* No results state */
.search-no-results {
    max-width: 680px;
    margin: var(--space-3xl) auto;
    text-align: center;
}

.search-no-results__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 96px;
    height: 96px;
    background: var(--accent-gold);
    border-radius: var(--border-radius-lg);
    color: var(--white);
    font-size: 2.5rem;
    margin-bottom: var(--space-xl);
    box-shadow: 0 8px 30px rgba(168, 143, 29, 0.35);
}

.search-no-results__title {
    font-size: var(--font-size-2xl);
    color: #0A1E3C;
    margin-bottom: var(--space-md);
}

.search-no-results__text {
    color: var(--gray-dark);
    font-size: var(--font-size-base);
    margin-bottom: var(--space-xl);
}

.search-no-results__tips {
    text-align: left;
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: var(--border-radius-lg);
    padding: var(--space-xl);
    margin-bottom: var(--space-xl);
    box-shadow: var(--shadow-sm);
}

.search-no-results__tips-title {
    font-size: var(--font-size-base);
    font-weight: 700;
    color: #0A1E3C;
    margin-bottom: var(--space-md);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
}

.search-no-results__tips-title i {
    color: var(--accent-gold);
}

.search-no-results__tips ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
}

.search-no-results__tips ul li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: var(--font-size-sm);
    color: var(--gray-dark);
    padding-left: var(--space-md);
    position: relative;
}

.search-no-results__tips ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    background: var(--accent-gold);
    border-radius: var(--border-radius-full);
}

.search-no-results__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
}

.search-no-results__categories {
    text-align: left;
}

/* Category chips (shared with 404) */
.search-no-results__cat-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-md);
}

.search-cat-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xs) var(--space-md);
    background: var(--white);
    border: 1px solid var(--gray-light);
    border-radius: var(--border-radius-full);
    font-size: var(--font-size-sm);
    color: var(--primary-dark);
    text-decoration: none;
    transition: background var(--transition-fast), border-color var(--transition-fast),
                color var(--transition-fast);
}

.search-cat-chip:hover {
    background: var(--accent-gold-wcag);
    border-color: var(--accent-gold-wcag);
    color: var(--white);
}

.search-cat-chip__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 5px;
    background: var(--gray-light);
    border-radius: var(--border-radius-full);
    font-size: 11px;
    font-weight: 600;
    color: var(--gray-dark);
    transition: background var(--transition-fast), color var(--transition-fast);
}

.search-cat-chip:hover .search-cat-chip__count {
    background: rgba(255, 255, 255, 0.25);
    color: var(--white);
}

/* Outline dark button */
.btn-outline-dark {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-xl);
    border: 2px solid var(--primary-dark);
    border-radius: var(--border-radius-sm);
    color: var(--primary-dark);
    font-size: var(--font-size-sm);
    font-weight: 600;
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
    cursor: pointer;
    background: transparent;
    font-family: var(--font-primary);
}

.btn-outline-dark:hover {
    background: var(--primary-dark);
    color: var(--white);
}

/* =====================================================
   404 PAGE
   Used in: 404.php
   ===================================================== */

.page-404-main {
    padding: var(--space-3xl) 0;
    background: var(--white-soft);
}

.page-404 {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-3xl) 0;
}

.page-404__number {
    font-size: clamp(6rem, 20vw, 12rem);
    font-weight: 800;
    color: var(--primary-dark);
    line-height: 1;
    opacity: 0.07;
    position: absolute;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.05em;
}

.page-404__icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100px;
    height: 100px;
    background: linear-gradient(135deg, #0A1E3C, #143B63);
    border-radius: var(--border-radius-lg);
    color: var(--accent-gold);
    font-size: 2.75rem;
    margin-bottom: var(--space-xl);
    box-shadow: var(--shadow-lg);
}

.page-404__title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    color: #0A1E3C;
    margin-bottom: var(--space-md);
}

.page-404__text {
    color: var(--gray-dark);
    font-size: var(--font-size-base);
    max-width: 520px;
    margin-bottom: var(--space-xl);
    line-height: 1.75;
}

.page-404__search {
    width: 100%;
    max-width: 560px;
    margin-bottom: var(--space-xl);
}

.page-404__search-form .search-bar-input {
    padding-right: 110px;
}

.page-404__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
}

.page-404-categories {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--gray-light);
    margin-top: var(--space-2xl);
}

.page-404-section-title {
    font-size: var(--font-size-xl);
    color: #0A1E3C;
    margin-bottom: var(--space-lg);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
}

.page-404-section-title i {
    color: var(--accent-gold);
}

.page-404-recent {
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--gray-light);
}

/* =====================================================
   GUTENBERG BLOCK STYLES
   ===================================================== */

/* Wide and full alignments */
.wp-block-image.alignwide,
.wp-block-gallery.alignwide,
.wp-block-cover.alignwide {
    max-width: min(100%, 1100px);
    margin-left: auto;
    margin-right: auto;
}

.wp-block-image.alignfull,
.wp-block-cover.alignfull {
    max-width: 100%;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
}

/* Block quotes */
.wp-block-quote {
    border-left: 4px solid var(--accent-gold);
    padding: var(--space-md) var(--space-xl);
    background: var(--white-soft);
    border-radius: 0 var(--border-radius-sm) var(--border-radius-sm) 0;
    font-style: italic;
    color: var(--gray-dark);
}

.wp-block-quote cite {
    display: block;
    margin-top: var(--space-sm);
    font-size: var(--font-size-sm);
    font-style: normal;
    color: var(--primary-dark);
    font-weight: 600;
}

/* Separator */
.wp-block-separator {
    border: none;
    border-top: 2px solid var(--gray-light);
    margin: var(--space-xl) 0;
}

.wp-block-separator.is-style-wide {
    border-top-color: var(--accent-gold);
}

/* Buttons */
.wp-block-button .wp-block-button__link {
    background: var(--accent-gold);
    color: var(--white);
    border-radius: var(--border-radius-sm);
    padding: var(--space-sm) var(--space-xl);
    font-size: var(--font-size-sm);
    font-weight: 600;
    transition: background var(--transition-fast);
}

.wp-block-button .wp-block-button__link:hover {
    background: #8B7718;
    color: var(--white);
}

.wp-block-button.is-style-outline .wp-block-button__link {
    background: transparent;
    border: 2px solid var(--accent-gold);
    color: var(--accent-gold);
}

.wp-block-button.is-style-outline .wp-block-button__link:hover {
    background: var(--accent-gold);
    color: var(--white);
}

/* Table */
.wp-block-table table {
    width: 100%;
    border-collapse: collapse;
}

.wp-block-table th,
.wp-block-table td {
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--gray-light);
}

.wp-block-table thead th {
    background: var(--primary-dark);
    color: var(--white);
}

/* Pullquote */
.wp-block-pullquote {
    border-top: 4px solid var(--accent-gold);
    border-bottom: 4px solid var(--accent-gold);
    padding: var(--space-xl);
    text-align: center;
    color: var(--primary-dark);
}

.wp-block-pullquote blockquote p {
    font-size: var(--font-size-xl);
    font-style: italic;
    font-weight: 500;
}

/* Code */
.wp-block-code {
    background: var(--white-soft);
    border: 1px solid var(--gray-light);
    border-radius: var(--border-radius-md);
    padding: var(--space-lg);
    overflow-x: auto;
}

/* Cover block */
.wp-block-cover {
    border-radius: var(--border-radius-lg);
    overflow: hidden;
}

/* ══════════════════════════════════════════════════
   MEJORA: Cards de noticias — Design System FLCH
   Junio 2026 — Modernización
   ══════════════════════════════════════════════════ */

/* Card base */
.post-card,
.sp-smart-post-show-pro article,
.sp-post-author-area,
article.type-post {
  background: #fff;
  border-radius: 1rem;
  border: 1px solid #E2E8F0;
  overflow: hidden;
  transition: transform 0.25s cubic-bezier(.22,.68,0,1.15),
              box-shadow 0.25s;
}
.post-card:hover,
.sp-smart-post-show-pro article:hover,
article.type-post:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 32px rgba(20,59,99,.12);
  border-color: rgba(168,143,29,.3);
}

/* Thumbnail con aspect-ratio */
.post-card .post-thumbnail img,
.post-card img,
.sp-post-thumb img,
article.type-post img {
  aspect-ratio: 16/9;
  object-fit: cover;
  width: 100%;
  transition: transform 0.4s ease;
}
.post-card:hover img,
article.type-post:hover img {
  transform: scale(1.03);
}

/* Título de la noticia */
.post-card .entry-title,
.post-card h2,
.post-card h3,
.sp-post-title,
article.type-post .entry-title {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9375rem;
  font-weight: 600;
  color: #143B63;
  line-height: 1.4;
  margin-bottom: 0.5rem;
}

/* Botón "LEER MÁS" — style FLCH */
.post-card .more-link,
.post-card a.more-link,
a.more-link,
.leer-mas,
a[class*="leer"],
.read-more-btn,
.sp-read-more,
article .more-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: #143B63 !important;
  font-size: 0.8125rem;
  font-weight: 700;
  text-decoration: none;
  border: 1.5px solid #143B63;
  padding: 0.375rem 1rem;
  border-radius: 9999px;
  transition: all 0.18s ease;
  margin-top: 0.75rem;
}
.post-card .more-link:hover,
a.more-link:hover,
.sp-read-more:hover {
  background: #143B63;
  color: #fff !important;
  transform: translateY(-1px);
}

/* Fecha de publicación */
.post-card .entry-date,
.post-date,
.sp-post-date {
  font-size: 0.75rem;
  color: #94a3b8;
  margin-bottom: 0.5rem;
  display: flex;
  align-items: center;
  gap: 4px;
}

