/* ========================================
   MAIN STYLES - LETRAS FLCH
   Variables inline (fix @import relativo)
   ======================================== */

/* ===== DESIGN TOKENS - LETRAS FLCH ===== */
:root {
    /* ===== COLORES PRIMARIOS ===== */
    --primary-dark: #143B63;
    --primary-text: #3A3A3A;

    /* ===== COLORES SECUNDARIOS ===== */
    --secondary-blue: #2457A6;
    --secondary-light: #69BCE2;
    --secondary-muted: #7FA9CC;
    --secondary-lavender: #B3B0CC;

    /* ===== ACENTO ESTRATÉGICO ===== */
    --accent-gold: #A88F1D;
    --color-accent: #A88F1D;
    --color-accent-dark: #8B7718;
    --accent-gold-wcag: #7A6600;

    /* ===== NEUTROS ===== */
    --white: #FFFFFF;
    --white-soft: #F5F7FA;
    --gray-light: #E5E9F0;
    --gray-medium: #CED4DA;
    --gray-dark: #6C757D;
    --black: #212529;

    /* ===== ESPACIADO BASE ===== */
    --space-unit: 8px;
    --space-xs: calc(var(--space-unit) * 1);
    --space-sm: calc(var(--space-unit) * 2);
    --space-md: calc(var(--space-unit) * 3);
    --space-lg: calc(var(--space-unit) * 4);
    --space-xl: calc(var(--space-unit) * 6);
    --space-2xl: calc(var(--space-unit) * 8);
    --space-3xl: calc(var(--space-unit) * 10);

    /* ===== TIPOGRAFÍA ===== */
    --font-primary: 'DM Sans', sans-serif;  /* FIX: Poppins → DM Sans */
    --font-size-xs: 0.75rem;
    --font-size-sm: 0.875rem;
    --font-size-base: 1rem;
    --font-size-md: 1.125rem;
    --font-size-lg: 1.25rem;
    --font-size-xl: 1.5rem;
    --font-size-2xl: 2rem;
    --font-size-3xl: 2.5rem;
    --font-size-4xl: 3rem;

    /* ===== BORDES ===== */
    --border-radius-sm: 4px;
    --border-radius-md: 8px;
    --border-radius-lg: 12px;
    --border-radius-full: 9999px;

    /* ===== SOMBRAS ===== */
    --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);
    --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.12);
    --shadow-gold: 0 4px 16px rgba(168, 143, 29, 0.2);

    /* ===== TRANSICIONES ===== */
    --transition-fast: 0.2s ease;
    --transition-base: 0.3s ease;
    --transition-slow: 0.5s ease;

    /* ===== Z-INDEX ===== */
    --z-dropdown: 100;
    --z-sticky: 200;
    --z-fixed: 300;
    --z-modal: 400;
    --z-popover: 500;
    --z-tooltip: 600;
}

/* ===== RESET Y BASE ===== */
*,
*::before,
*::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html {
    font-size: 16px;
    scroll-behavior: smooth;
}

body {
    font-family: var(--font-primary);
    font-size: var(--font-size-base);
    line-height: 1.6;
    color: var(--primary-text);
    background-color: var(--white);
    overflow-x: hidden;
}

/* ===== TIPOGRAFÍA ===== */
h1,
h2,
h3,
h4,
h5,
h6 {
    font-weight: 600;
    line-height: 1.3;
    color: var(--primary-dark);
    margin-bottom: var(--space-md);
}

h1 {
    font-size: var(--font-size-4xl);
}

h2 {
    font-size: var(--font-size-3xl);
}

h3 {
    font-size: var(--font-size-2xl);
}

h4 {
    font-size: var(--font-size-xl);
}

h5 {
    font-size: var(--font-size-lg);
}

h6 {
    font-size: var(--font-size-md);
}

p {
    margin-bottom: var(--space-md);
}

a {
    color: var(--primary-dark);
    text-decoration: none;
    transition: color var(--transition-fast);
}

a:hover {
    color: var(--accent-gold-wcag); /* #7A6600 — WCAG AA sobre blanco */
}

/* ===== LAYOUT ===== */
.container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-lg);
}

@media (max-width: 768px) {
    .container {
        padding: 0 var(--space-md);
    }
}

/* Grid system */
.grid {
    display: grid;
    gap: var(--space-lg);
}

.grid-2 {
    grid-template-columns: repeat(2, 1fr);
}

.grid-3 {
    grid-template-columns: repeat(3, 1fr);
}

.grid-4 {
    grid-template-columns: repeat(4, 1fr);
}

@media (max-width: 1024px) {
    .grid-4 {
        grid-template-columns: repeat(3, 1fr);
    }
}

@media (max-width: 768px) {

    .grid-2,
    .grid-3,
    .grid-4 {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 480px) {

    .grid-2,
    .grid-3,
    .grid-4 {
        grid-template-columns: 1fr;
    }
}

/* Flex utilities */
.flex {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
}

.flex-between {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
}

.flex-center {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-md);
}

/* ===== HEADER ===== */
.header-letras {
    background: var(--primary-dark);
    padding: var(--space-md) 0;
    position: relative;
    width: 100%;
    z-index: var(--z-fixed);
    box-shadow: var(--shadow-md);
}

.header-letras.sticky {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    animation: slideDown 0.3s ease;
}

@keyframes slideDown {
    from {
        transform: translateY(-100%);
    }

    to {
        transform: translateY(0);
    }
}

.header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
}

/* Logo */
.header-logo img {
    height: 60px;
    width: auto;
    display: block;
}

/* Navegación principal — estilos completos gestionados en header.php inline CSS */
/* Los estilos de .main-menu, .main-menu li, .main-menu .sub-menu, etc.
   están definidos en el bloque <style> del header.php para evitar conflictos
   de orden de carga. No duplicar aquí. */

/* Menu Toggle (móvil) */
.menu-toggle {
    display: none;
    width: 40px;
    height: 40px;
    background: transparent;
    border: none;
    cursor: pointer;
    position: relative;
    z-index: var(--z-fixed);
}

.menu-toggle span {
    display: block;
    width: 25px;
    height: 2px;
    background: var(--white);
    margin: 5px auto;
    transition: all var(--transition-base);
}

.menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
}

.menu-toggle.active span:nth-child(2) {
    opacity: 0;
}

.menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
}

/* ===== HERO SECTION ===== */
.hero-letras {
    background: linear-gradient(135deg, var(--primary-dark) 0%, var(--secondary-blue) 100%);
    padding: var(--space-3xl) 0;
    color: var(--white);
    position: relative;
    overflow: hidden;
}

.hero-letras::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.1"><path d="M20,20 L80,20 L80,80 L20,80 Z" fill="none" stroke="white" stroke-width="0.5"/><circle cx="50" cy="50" r="10" fill="none" stroke="white" stroke-width="0.5"/></svg>');
    background-size: 50px 50px;
    pointer-events: none;
}

.hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
    position: relative;
    z-index: 2;
}

.hero-badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(5px);
    padding: var(--space-xs) var(--space-md);
    border-radius: var(--border-radius-full);
    font-size: var(--font-size-xs);
    font-weight: 600;
    margin-bottom: var(--space-md);
    border-left: 3px solid var(--accent-gold);
    text-transform: uppercase;
    letter-spacing: 1px;
}

.hero-title {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-md);
    color: var(--white);
}

.hero-description {
    font-size: var(--font-size-lg);
    opacity: 0.9;
    margin-bottom: var(--space-xl);
    max-width: 600px;
}

.hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
}

.hero-image {
    position: relative;
}

.hero-image img {
    width: 100%;
    border-radius: var(--border-radius-lg);
    box-shadow: 20px 20px 40px rgba(0, 0, 0, 0.3);
}

.hero-accent {
    position: absolute;
    bottom: -20px;
    right: -20px;
    width: 100px;
    height: 100px;
    border: 5px solid var(--accent-gold);
    border-radius: var(--border-radius-md);
    z-index: -1;
}

/* ===== BOTONES ===== */
.btn {
    display: inline-block;
    padding: var(--space-sm) var(--space-xl);
    font-size: var(--font-size-sm);
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    border-radius: var(--border-radius-sm);
    transition: all var(--transition-base);
    cursor: pointer;
    border: 2px solid transparent;
    letter-spacing: 0.5px;
    text-transform: uppercase;
}

/* Botón primario - DORADO (uso estratégico) */
.btn-primary {
    background: var(--accent-gold-wcag); /* #7A6600 — blanco sobre dorado: 5.1:1 WCAG AA */
    color: var(--white);
    border-color: var(--accent-gold-wcag);
}

.btn-primary:hover {
    background: transparent;
    border-color: var(--accent-gold-wcag);
    color: var(--accent-gold-wcag);
    transform: translateY(-2px);
    box-shadow: var(--shadow-gold);
}

/* Botón secundario - Outline */
.btn-outline {
    background: transparent;
    border-color: var(--white);
    color: var(--white);
}

.btn-outline:hover {
    background: var(--white);
    color: var(--primary-dark);
    transform: translateY(-2px);
}

/* Botón para cards */
.btn-card {
    background: transparent;
    color: var(--primary-dark);
    padding: var(--space-xs) 0;
    position: relative;
    border-radius: 0;
    text-transform: none;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
}

.btn-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent-gold);
    transition: width var(--transition-base);
}

.btn-card:hover::after {
    width: 100%;
}

.btn-card:hover {
    color: var(--primary-dark);
    transform: none;
}

.btn-card i {
    font-size: var(--font-size-xs);
    transition: transform var(--transition-fast);
}

.btn-card:hover i {
    transform: translateX(5px);
}

/* Botón terciario */
.btn-tertiary {
    background: var(--secondary-light);
    color: var(--primary-dark);
}

.btn-tertiary:hover {
    background: var(--secondary-blue);
    color: var(--white);
}

/* ===== CARDS ===== */
.card {
    background: var(--white);
    border-radius: var(--border-radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-base);
    height: 100%;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--gray-light);
}

.card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
}

.card-image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16/9;
}

.card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
}

.card:hover .card-image img {
    transform: scale(1.05);
}

.card-category {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    background: var(--accent-gold);
    color: var(--white);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--border-radius-full);
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 1;
}

.card-content {
    padding: var(--space-lg);
    flex: 1;
    display: flex;
    flex-direction: column;
}

.card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    font-size: var(--font-size-xs);
    color: var(--secondary-muted);
}

.card-meta i {
    color: var(--accent-gold);
    margin-right: var(--space-xs);
}

.card-title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: var(--space-sm);
}

.card-title a {
    color: var(--primary-dark);
    text-decoration: none;
}

.card-title a:hover {
    color: var(--accent-gold-wcag);
}

.card-excerpt {
    color: var(--primary-text);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    margin-bottom: var(--space-md);
    flex: 1;
}

/* ===== SECCIÓN DE NOTICIAS ===== */
.news-section {
    padding: var(--space-3xl) 0;
    background: var(--white-soft);
}

.section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-2xl);
    flex-wrap: wrap;
    gap: var(--space-md);
}

.section-title {
    font-size: var(--font-size-3xl);
    margin-bottom: 0;
    position: relative;
    padding-bottom: var(--space-sm);
}

.section-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 3px;
    background: var(--accent-gold);
}

.section-link {
    color: var(--primary-dark);
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    transition: gap var(--transition-fast);
}

.section-link:hover {
    gap: var(--space-sm);
    color: var(--accent-gold-wcag);
}

/* Noticia destacada */
.news-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-xl);
}

.news-featured {
    background: var(--white);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
}

.featured-card {
    display: flex;
    flex-direction: column;
    height: 100%;
}

.featured-image {
    aspect-ratio: 16/9;
    overflow: hidden;
}

.featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
}

.featured-card:hover .featured-image img {
    transform: scale(1.05);
}

.featured-content {
    padding: var(--space-xl);
    position: relative;
}

.featured-badge {
    position: absolute;
    top: -12px;
    left: var(--space-xl);
    background: var(--accent-gold);
    color: var(--white);
    padding: var(--space-xs) var(--space-lg);
    border-radius: var(--border-radius-full);
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
}

.featured-content h3 {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-md);
}

.featured-content h3 a {
    color: var(--primary-dark);
}

.featured-content h3 a:hover {
    color: var(--accent-gold);
}

.featured-content p {
    color: var(--primary-text);
    margin-bottom: var(--space-lg);
}

/* Lista de noticias */
.news-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
}

.news-item {
    display: flex;
    gap: var(--space-md);
    background: var(--white);
    padding: var(--space-md);
    border-radius: var(--border-radius-md);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-base);
}

.news-item:hover {
    transform: translateX(5px);
    box-shadow: var(--shadow-md);
}

.news-item-image {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    border-radius: var(--border-radius-sm);
    overflow: hidden;
}

.news-item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.news-item-content {
    flex: 1;
}

.news-item-date {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--secondary-muted);
    margin-bottom: var(--space-xs);
}

.news-item-content h4 {
    font-size: var(--font-size-base);
    margin-bottom: 0;
    line-height: 1.4;
}

.news-item-content h4 a {
    color: var(--primary-dark);
}

.news-item-content h4 a:hover {
    color: var(--accent-gold);
}

/* ===== SECCIONES ACADÉMICAS ===== */
.academic-section {
    padding: var(--space-3xl) 0;
}

.programs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
}

.program-card {
    background: var(--white);
    padding: var(--space-xl);
    border-radius: var(--border-radius-lg);
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-base);
    border: 1px solid var(--gray-light);
    text-align: center;
}

.program-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent-gold);
}

.program-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto var(--space-lg);
    background: var(--secondary-light);
    border-radius: var(--border-radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: var(--primary-dark);
    transition: all var(--transition-base);
}

.program-card:hover .program-icon {
    background: var(--accent-gold);
    color: var(--white);
    transform: rotateY(180deg);
}

.program-card h3 {
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-sm);
}

.program-card p {
    color: var(--gray-dark);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-lg);
}

.program-list {
    list-style: none;
    margin-bottom: var(--space-lg);
    text-align: left;
}

.program-list li {
    padding: var(--space-xs) 0;
    border-bottom: 1px dashed var(--gray-light);
}

.program-list li:last-child {
    border-bottom: none;
}

.program-list a {
    color: var(--primary-text);
    font-size: var(--font-size-sm);
    display: block;
    transition: all var(--transition-fast);
}

.program-list a:hover {
    color: var(--accent-gold-wcag);
    padding-left: var(--space-xs);
}

.program-link {
    color: var(--primary-dark);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
}

.program-link:hover {
    color: var(--accent-gold);
    gap: var(--space-sm);
}

/* ===== FOOTER ===== */
.footer-letras {
    background: var(--primary-dark);
    color: var(--white);
    padding: var(--space-3xl) 0 var(--space-xl);
}

.footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
}

.footer-widget h4 {
    color: var(--white);
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-lg);
    position: relative;
    padding-bottom: var(--space-sm);
}

.footer-widget h4::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 2px;
    background: var(--accent-gold);
}

.footer-widget p {
    color: var(--secondary-muted);
    font-size: var(--font-size-sm);
    line-height: 1.6;
}

.footer-menu {
    list-style: none;
}

.footer-menu li {
    margin-bottom: var(--space-sm);
}

.footer-menu a {
    color: var(--secondary-muted);
    font-size: var(--font-size-sm);
    transition: all var(--transition-fast);
    display: inline-block;
}

.footer-menu a:hover {
    color: var(--white);
    transform: translateX(5px);
}

.footer-contact {
    list-style: none;
}

.footer-contact li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
    color: var(--secondary-muted);
    font-size: var(--font-size-sm);
}

.footer-contact li i {
    color: var(--accent-gold);
    font-size: var(--font-size-md);
    min-width: 24px;
    margin-top: 2px;
}

.footer-contact a {
    color: var(--secondary-muted);
}

.footer-contact a:hover {
    color: var(--white);
}

.social-links {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-md);
}

.social-links a {
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--border-radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--white);
    transition: all var(--transition-base);
}

.social-links a:hover {
    background: var(--accent-gold);
