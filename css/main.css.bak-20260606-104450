/* =====================================================
   CARD-NOTICIA — BEM component
   Used in: template-parts/card-noticia.php
   ===================================================== */

/* Utilidad line-clamp (fallback para navegadores sin Tailwind) */
.line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

/* SR-only para accesibilidad */
.sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
}

.card-noticia {
    display: flex;
    flex-direction: column;
    background: var(--white);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    border: 1px solid var(--gray-light);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-base), box-shadow var(--transition-base),
                border-color var(--transition-base);
    height: 100%;
}

.card-noticia:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(168, 143, 29, 0.3);
}

/* Imagen */
.card-noticia__image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, #0A1E3C, #1E4A7A);
}

.card-noticia__img-link {
    display: block;
    width: 100%;
    height: 100%;
}

.card-noticia__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
}

.card-noticia:hover .card-noticia__img {
    transform: scale(1.05);
}

.card-noticia__img-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    min-height: 180px;
    color: rgba(255, 255, 255, 0.2);
    font-size: 2.5rem;
}

/* Badge de categoría */
.card-noticia__badge {
    position: absolute;
    top: var(--space-sm);
    left: var(--space-sm);
    padding: 3px var(--space-sm);
    background: var(--accent-gold);
    color: var(--white);
    font-size: var(--font-size-xs);
    font-weight: 600;
    border-radius: var(--border-radius-full);
    box-shadow: var(--shadow-sm);
    z-index: 1;
    text-decoration: none;
    transition: background var(--transition-fast);
}

.card-noticia__badge:hover {
    background: #8B7718;
    color: var(--white);
}

/* Cuerpo */
.card-noticia__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--space-lg);
}

/* Meta (fecha) */
.card-noticia__meta {
    margin-bottom: var(--space-sm);
}

.card-noticia__date {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: var(--font-size-xs);
    color: var(--gray-dark);
}

.card-noticia__date i {
    color: var(--accent-gold);
}

/* Título */
.card-noticia__title {
    font-size: var(--font-size-base);
    font-weight: 600;
    line-height: 1.4;
    color: #0A1E3C;
    margin-bottom: var(--space-sm);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--transition-fast);
}

.card-noticia:hover .card-noticia__title {
    color: var(--accent-gold-wcag); /* #7A6600 — WCAG AA sobre blanco */
}

.card-noticia__title a {
    color: inherit;
    text-decoration: none;
}

.card-noticia__title a:hover {
    text-decoration: underline;
}

/* Extracto */
.card-noticia__excerpt {
    font-size: var(--font-size-sm);
    color: var(--gray-dark);
    line-height: 1.6;
    margin-bottom: var(--space-md);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

/* Leer más */
.card-noticia__readmore {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--accent-gold-wcag); /* #7A6600 — WCAG AA sobre blanco */
    text-decoration: none;
    margin-top: auto;
    transition: gap var(--transition-fast), color var(--transition-fast);
}

.card-noticia__readmore:hover {
    color: var(--accent-gold-wcag);
    gap: 10px;
}

.card-noticia__readmore i {
    font-size: 11px;
    transition: transform var(--transition-fast);
}

