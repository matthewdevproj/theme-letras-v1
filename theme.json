        "typography": {
          "fontFamily": "var(--font-display)",
          "fontWeight": "600",
          "lineHeight": "1.2"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--font-display)",
          "fontWeight": "600",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--font-display)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--font-body)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "link": {
        "color": {
          "text": "var(--navy)"
        },
        "typography": {
          "textDecoration": "none"
        },
        ":hover": {
          "color": {
            "text": "var(--gold)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--gold)",
          "text": "#FFFFFF"
        },
        "typography": {
          "fontFamily": "var(--font-body)",
          "fontWeight": "500"
        },
        "border": {
          "radius": "6px"
        }
      },
      "caption": {
        "typography": {
          "fontSize": "0.8125rem",
          "fontFamily": "var(--font-body)"
        }
      }
    },
    "blocks": {
      "core/paragraph": {
        "typography": {
          "fontSize": "1rem",
          "lineHeight": "1.6"
        }
      },
      "core/heading": {
        "typography": {
          "fontWeight": "600"
        }
      },
      "core/button": {
        "border": {
          "radius": "6px"
        },
        "color": {
          "background": "var(--gold)",
          "text": "#FFFFFF"
        }
      },
      "core/separator": {
        "border": {
          "color": "var(--gray-200)",
          "width": "1px"
        }
      },
      "core/quote": {
        "typography": {
          "fontFamily": "var(--font-display)",
          "fontStyle": "italic"
        }
      },
      "core/pullquote": {
        "typography": {
          "fontFamily": "var(--font-display)"
        },
        "border": {
          "color": "var(--gold)"
        }
      }
